generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
 }

model user {
  id           Int             @id @default(autoincrement())
  user_id      String?         @unique(map: "user_id") @db.VarChar(300)
  pw           String?         @db.VarChar(300)
  nickname     String?         @unique(map: "nickname") @db.VarChar(300)
  address      String?         @db.VarChar(300)
  address2     String?         @db.VarChar(300)
  point        Int?            @default(0)
  created_at   DateTime?       @db.Date
  updated_at   DateTime?       @db.Date
  is_active    user_is_active?
  user_lat     Float?
  user_lng     Float?
  firebase_uid String?         @unique @db.VarChar(128)
  
  // 🚀 관계 설정 (Relations)
  product      product[]       // 유저가 등록한 상품들 (1:N)
  orders       order[]         // 유저가 구매 신청한 내역들 (1:N)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model product {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(300)
  price       Int
  description String    @db.Text
  image_url   String    @db.VarChar(1000)
  
  // 💡 기존 status 컬럼을 그대로 활용합니다.
  status      String    @default("sale") @db.VarChar(20)
  
  created_at  DateTime? @default(now()) @db.DateTime(0)
  updated_at  DateTime? @default(now()) @db.DateTime(0)
  seller_id   Int
  user        user      @relation(fields: [seller_id], references: [id], onDelete: Cascade, map: "FK_Product_User")

  // 🚀 관계 설정 (Relations)
  orders      order[]   // 하나의 상품에 달린 여러 구매 신청들 (1:N)

  @@index([seller_id], map: "FK_Product_User")
}

// 🚀 [신규 추가] 구매 신청(주문) 테이블
model order {
  id         Int      @id @default(autoincrement())
  product_id Int
  buyer_id   Int      // 구매를 신청한 유저의 고유 id
  
  // 신청서 상태: "pending"(수락 대기) | "accepted"(수락/진행중) | "completed"(거래 완료) | "canceled"(거절/취소)
  status     String   @default("pending") @db.VarChar(20)
  
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @db.DateTime(0)

  // 💡 중복 및 에러가 발생하지 않도록 명확한 외래키 맵핑명을 부여합니다.
  product    product  @relation(fields: [product_id], references: [id], onDelete: Cascade, map: "FK_Order_Product")
  buyer      user     @relation(fields: [buyer_id], references: [id], onDelete: Cascade, map: "FK_Order_Buyer")

  @@index([product_id], map: "FK_Order_Product")
  @@index([buyer_id], map: "FK_Order_Buyer")
}

enum user_is_active {
  Y
  N
}